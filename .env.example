# ─────────────────────────────────────────────────────────────────────────────
# EQEmu GM Dashboard — Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Timezone ──────────────────────────────────────────────────────────────────
# Standard tz database name. Examples: America/New_York, America/Chicago,
# America/Denver, America/Los_Angeles, Europe/London, UTC
TZ=America/Chicago

# ── Dashboard port ────────────────────────────────────────────────────────────
# Port the dashboard is accessible on from your browser.
DASHBOARD_PORT=8765

# ── MariaDB / MySQL connection ────────────────────────────────────────────────
# For akk-stack: DB_HOST is usually the host IP or the docker container IP.
# Do NOT use the container name here — reports_server.py connects from outside
# the stack network unless you add it to the same docker network.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=your_mariadb_root_password_here
DB_NAME=peq

# ── Spire URL ─────────────────────────────────────────────────────────────────
# Full URL to your Spire API server (no trailing slash).
SPIRE_URL=http://127.0.0.1:3000

# ── Host paths ────────────────────────────────────────────────────────────────
# REPORTS_DIR: where generated index.html and .xlsx files are stored on the host.
REPORTS_DIR=/tmp/eqemu-reports

# SCRIPTS_DIR: directory on the host that contains gm_excel.py.
# The gm-worker container mounts this as /scripts (read-only).
SCRIPTS_DIR=/opt/eqemu-gm-dashboard

# ── akk-stack path (used by gm_export.sh on the host) ────────────────────────
# Full path to the directory containing your docker-compose.yml and .env
# for the EQEmu akk-stack. gm_export.sh reads MARIADB_ROOT_PASSWORD from here.
STACK_DIR=/opt/eqemu/server

# ── Export daemon settings ────────────────────────────────────────────────────
# How often (seconds) gm_export.sh regenerates the report.
INTERVAL=60

# ── Docker container names ────────────────────────────────────────────────────
# Must match the container_name values in docker-compose.yml.
WORKER_CONTAINER=eqemu-gm-worker
MARIADB_CONTAINER=mariadb

# ── Spire token ───────────────────────────────────────────────────────────────
# Path on the host where the Spire bearer token is stored.
# Generate one inside Spire under Settings → API Tokens.
SPIRE_TOKEN_FILE=/opt/eqemu-gm-dashboard/spire_token.txt
